PORT=3000
CORS_ORIGIN=*

# Use DATABASE_URL on Railway if you connect a MySQL service.
DATABASE_URL=mysql://user:password@host:3306/database

# Or use individual MySQL variables.
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=123456
MYSQLDATABASE=testdb

# Set false in production if you do not want TypeORM to auto-sync schema.
DB_SYNC=true
DB_SSL=false
